# Copy this file to .env in this same directory (integrations/gitlab-v2/).
# Required for `make run`: real values for PORT client id/secret and GitLab token (not placeholders).
#
OCEAN__EVENT_LISTENER='{"type":"POLLING"}'
OCEAN__PORT__BASE_URL="https://api.getport.io"
OCEAN__INTEGRATION__CONFIG__GITLAB_TOKEN="Your Gitlab Token"
OCEAN__INTEGRATION__IDENTIFIER="my-gitlab-v2-integration"
OCEAN__INTEGRATION__TYPE="gitlab-v2"
OCEAN__PORT__CLIENT_ID="<port-client-id>"
OCEAN__PORT__CLIENT_SECRET="<port-client-secret>"
OCEAN__BASE_URL=""
