        },
        "list_amount": {
          "type": "number",
          "title": "List Amount"
        },
        "requests": {
          "type": "number",
          "title": "Requests"
        }
      },
      "required": [
        "record_date"
      ]
    },
    "mirrorProperties": {},
    "calculationProperties": {
      "discount_amount": {
        "title": "Discount Amount",
