        },
        "user_id": {
          "type": "string",
          "title": "User ID"
        },
        "user_name": {
          "type": "string",
          "title": "User Name"
        },
        "email": {
          "type": "string",
          "format": "user",
          "title": "Email"
        },
        "deleted": {
          "type": "boolean",
          "title": "Deleted User"
        },
        "product": {
          "type": "string",
          "title": "Product"
