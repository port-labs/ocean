      "AccountId": "123456789012",
      "Region": "us-east-1"
    }
  },
  {
    "Type": "AWS::CodePipeline::Stage",
    "Properties": {
      "PipelineName": "my-app-pipeline",
      "PipelineArn": "arn:aws:codepipeline:us-east-1:123456789012:my-app-pipeline",
      "StageName": "Build",
