[
  {
    "identifier": "cursorDailyUsage",
    "description": "Daily team usage metrics from Cursor Admin API",
    "title": "Cursor Daily Usage",
    "icon": "Cursor",
    "schema": {
      "properties": {
        "day": {
          "type": "string",
          "format": "date-time",
          "title": "Day"
        },
        "user_id": {
          "type": "string",
          "title": "User ID"
        },
        "email": {
          "type": "string",
          "title": "User Email",
          "format": "email"
        },
        "is_active": {
          "type": "boolean",
          "title": "Active"
        },
        "total_lines_added": {
          "type": "number",
          "title": "Total Lines Added"
        },
        "total_lines_deleted": {
          "type": "number",
          "title": "Total Lines Deleted"
        },
        "accepted_lines_added": {
          "type": "number",
          "title": "Accepted Lines Added"
        },
        "accepted_lines_deleted": {
          "type": "number",
          "title": "Accepted Lines Deleted"
        },
        "total_applies": {
          "type": "number",
          "title": "Total Applies"
        },
        "total_accepts": {
          "type": "number",
          "title": "Total Accepts"
        },
        "total_rejects": {
          "type": "number",
          "title": "Total Rejects"
        },
        "composer_requests": {
          "type": "number",
          "title": "Composer Requests"
        },
        "chat_requests": {
          "type": "number",
          "title": "Chat Requests"
        },
        "agent_requests": {
          "type": "number",
          "title": "Agent Requests"
        },
        "most_used_model": {
          "type": "string",
          "title": "Most Used Model"
        },
        "total_tabs_shown": {
          "type": "number",
          "title": "Total Tabs Shown"
        },
        "total_tabs_accepted": {
          "type": "number",
          "title": "Total Tabs Accepted"
        },
        "subscription_included_reqs": {
          "type": "number",
          "title": "Subscription Included Requests"
        },
        "api_key_reqs": {
          "type": "number",
          "title": "API Key Requests"
        },
        "usage_based_reqs": {
          "type": "number",
          "title": "Usage-based Requests"
        },
        "bugbot_usages": {
          "type": "number",
          "title": "Bugbot Usages"
        }
      },
      "required": []
    },
    "mirrorProperties": {},
    "calculationProperties": {
      "acceptance_rate": {
        "title": "Acceptance Rate",
        "description": "Accepted AI suggestions as a percentage of accepted + rejected suggestions",
        "calculation": "if (.properties.total_accepts + .properties.total_rejects) > 0 then (.properties.total_accepts / (.properties.total_accepts + .properties.total_rejects)) * 100 else 0 end",
        "type": "number"
      }
    },
    "aggregationProperties": {},
    "relations": {}
  },
