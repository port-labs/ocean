OCEAN__PORT__CLIENT_ID=<port_client_id>
OCEAN__PORT__CLIENT_SECRET=<port_client_secret>
OCEAN__INTEGRATION__IDENTIFIER=claude-managed-agents
OCEAN__PORT__BASE_URL=https://api.getport.io
# Optional - Port MCP URL for auto-provisioned vault credentials. Defaults from OCEAN__PORT__BASE_URL region.
OCEAN__PORT__BASE_MCP_URL=https://mcp.port.io/v1
OCEAN__EVENT_LISTENER__TYPE=POLLING
OCEAN__INITIALIZE_PORT_RESOURCES=true
# Required to process live events (webhooks). Set to the integration's public base URL
# (for local testing, your ngrok base URL, e.g. https://<subdomain>.ngrok.app). Without it,
# incoming webhooks are queued but never processed.
OCEAN__BASE_URL=<integration_public_base_url>
OCEAN__INTEGRATION__CONFIG__ANTHROPIC_API_KEY=<anthropic_api_key>
OCEAN__INTEGRATION__CONFIG__ANTHROPIC_API_HOST=https://api.anthropic.com
OCEAN__INTEGRATION__CONFIG__ANTHROPIC_VERSION=2023-06-01
# Optional - required only for live events (webhooks). The signing secret from the Claude Console webhook configuration.
OCEAN__INTEGRATION__CONFIG__WEBHOOK_SIGNING_SECRET=<anthropic_webhook_signing_secret>
# Optional - GitHub PAT for github_repository session resources when authorization_token is omitted.
OCEAN__INTEGRATION__CONFIG__GITHUB_AUTHORIZATION_TOKEN=<github_pat>
