OCEAN__PORT__CLIENT_ID=<port_client_id>
OCEAN__PORT__CLIENT_SECRET=<port_client_secret>
OCEAN__INTEGRATION__IDENTIFIER=cursor-cloud-agents
OCEAN__PORT__BASE_URL=https://api.getport.io
OCEAN__EVENT_LISTENER__TYPE=POLLING
OCEAN__INITIALIZE_PORT_RESOURCES=true
# Required to process live events (webhooks) and to register the v0 webhook URL
# on newly launched agents. Set to the integration's public base URL (for local
# testing, your ngrok base URL, e.g. https://<subdomain>.ngrok.app). Without it,
# `create_agent`/`trigger_agent` runs can never be tracked to completion (v0
# `reportCompletion` will raise a validation error) and incoming webhooks are
# queued but never processed.
OCEAN__BASE_URL=<integration_public_base_url>
OCEAN__INTEGRATION__CONFIG__CURSOR_API_KEY=<cursor_api_key>
# Optional: sign and verify incoming Cursor webhooks.
# Generate with: openssl rand -hex 32
OCEAN__INTEGRATION__CONFIG__WEBHOOK_SIGNING_SECRET=<webhook_signing_secret>
OCEAN__INTEGRATION__CONFIG__CURSOR_API_HOST=https://api.cursor.com
OCEAN__INTEGRATION__CONFIG__CURSOR_CONSOLE_HOST=https://cursor.com
