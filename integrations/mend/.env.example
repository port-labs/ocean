# ---------------------------------------------------------------------------
# Port API connection
# Credentials and base URL used by the integration to talk to Port.
# Get clientId / clientSecret from Port → Builder → Credentials.
# ---------------------------------------------------------------------------
OCEAN__PORT__CLIENT_ID=<port_client_id>
OCEAN__PORT__CLIENT_SECRET=<port_client_secret>
OCEAN__PORT__BASE_URL=https://api.getport.io

# ---------------------------------------------------------------------------
# Integration identity
# Unique identifier registered on Port for this integration instance.
# Type is read from .port/spec.yaml — usually no need to override here.
# ---------------------------------------------------------------------------
OCEAN__INTEGRATION__IDENTIFIER=mend

# ---------------------------------------------------------------------------
# Event listener
# How the integration receives "resync now" signals.
#   POLLING       — periodic resync (paired with OCEAN__SCHEDULED_RESYNC_INTERVAL)
#   KAFKA         — listen on a Kafka topic
#   WEBHOOKS_ONLY — react only to incoming webhooks
# ---------------------------------------------------------------------------
OCEAN__EVENT_LISTENER__TYPE=POLLING

# ---------------------------------------------------------------------------
# Resync / bootstrap
# INITIALIZE_PORT_RESOURCES — on startup, create the blueprints and
#   port-app-config defined under .port/resources/ if they don't exist yet.
# SCHEDULED_RESYNC_INTERVAL — how often (minutes) the poller triggers a
#   resync. By default each tick performs a *partial* (delta) sync: only
#   findings from projects whose lastScanTime / creationDate changed since
#   the previous run are fetched. See FULL_SYNC_INTERVAL_MINUTES below for
#   how forced full resyncs are scheduled on top of this.
# ---------------------------------------------------------------------------
OCEAN__INITIALIZE_PORT_RESOURCES=true
OCEAN__SCHEDULED_RESYNC_INTERVAL=60

# ---------------------------------------------------------------------------
# Mend integration config
# MEND_ACTIVATION_KEY
# FULL_SYNC_INTERVAL_MINUTES — interval between forced full resyncs.
#   Most polls (driven by OCEAN__SCHEDULED_RESYNC_INTERVAL) do a partial
#   delta sync. Once this many minutes have elapsed since the last full
#   sync, the next poll bypasses the delta marker and fetches every
#   finding for every project — picks up changes that don't touch the
#   project record (status updates, suppressions, manual edits).
#   Default 720 (12 h). Set 0 to make every poll a full sync.
# ---------------------------------------------------------------------------
OCEAN__INTEGRATION__CONFIG__MEND_ACTIVATION_KEY=<mend_activation_key>
OCEAN__INTEGRATION__CONFIG__FULL_SYNC_INTERVAL_MINUTES=720

# ---------------------------------------------------------------------------
# Logging
# DEBUG / INFO / WARNING / ERROR
# ---------------------------------------------------------------------------
APPLICATION__LOG_LEVEL="INFO"
